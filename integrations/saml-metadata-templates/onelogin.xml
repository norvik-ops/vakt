<?xml version="1.0" encoding="UTF-8"?>
<!--
  OneLogin — SAML SP Metadata Template for Vakt

  How to use:
  1. In OneLogin Administration → Applications → Add App → SAML Test Connector (Advanced)
  2. Configuration tab:
     - ACS (Consumer) URL:       https://<your-vakt-domain>/api/v1/auth/saml/acs
     - ACS (Consumer) URL Validator: .*
     - Audience (EntityID):      https://<your-vakt-domain>/api/v1/auth/saml/metadata
     - Recipient:                https://<your-vakt-domain>/api/v1/auth/saml/acs
  3. Parameters tab:
     - NameID value: Email
     - email:       Email
     - firstName:   First Name
     - lastName:    Last Name
  4. More Actions → Download SAML Metadata and upload it in Vakt Settings → SAML
-->
<EntityDescriptor
  xmlns="urn:oasis:names:tc:SAML:2.0:metadata"
  entityID="https://YOUR_VAKT_DOMAIN/api/v1/auth/saml/metadata">

  <SPSSODescriptor
    AuthnRequestsSigned="false"
    WantAssertionsSigned="true"
    protocolSupportEnumeration="urn:oasis:names:tc:SAML:2.0:protocol">

    <NameIDFormat>
      urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
    </NameIDFormat>

    <AssertionConsumerService
      Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
      Location="https://YOUR_VAKT_DOMAIN/api/v1/auth/saml/acs"
      index="0"
      isDefault="true"/>

  </SPSSODescriptor>

</EntityDescriptor>
